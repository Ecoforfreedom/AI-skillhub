# ─── Database ───────────────────────────────────────────────────────────────
# PostgreSQL connection string
# For Docker Compose: postgresql://wsr:changeme@localhost:5432/work_skill_radar
DATABASE_URL="postgresql://user:password@localhost:5432/work_skill_radar"

# ─── GitHub ──────────────────────────────────────────────────────────────────
# Personal access token for GitHub API (required for crawler)
# Create at: https://github.com/settings/tokens (read-only, no scopes needed)
GITHUB_TOKEN="ghp_xxxxxxxxxxxxxxxxxxxx"

# ─── OpenAI ──────────────────────────────────────────────────────────────────
# OpenAI API key (required for AI enrichment)
OPENAI_API_KEY="sk-xxxxxxxxxxxxxxxxxxxxxxxx"

# Optional: custom base URL for OpenAI-compatible APIs (e.g., Azure, local)
# OPENAI_BASE_URL="https://api.openai.com/v1"

# Optional: model to use for enrichment (defaults to gpt-4o-mini)
# AI_MODEL="gpt-4o-mini"

# ─── Admin ───────────────────────────────────────────────────────────────────
# Password for /admin dashboard and admin API routes
ADMIN_PASSWORD="change-me-in-production"

# ─── Site ────────────────────────────────────────────────────────────────────
# Public URL (used for SEO metadata)
NEXT_PUBLIC_SITE_URL="https://your-domain.com"

# ─── Docker Compose (optional override) ──────────────────────────────────────
# Postgres password when using docker-compose
# POSTGRES_PASSWORD="changeme"
